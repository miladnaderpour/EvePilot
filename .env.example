EVEPILOT_EVE_NG_URL=http://10.1.2.3
EVEPILOT_EVE_NG_USERNAME=admin
EVEPILOT_EVE_NG_PASSWORD=change-me
EVEPILOT_EVE_NG_VERIFY_SSL=false
EVEPILOT_EVE_NG_TIMEOUT_SECONDS=10.0

EVEPILOT_LOG_OUTPUT=stdout
EVEPILOT_LOG_LEVEL=INFO
EVEPILOT_LOG_FORMAT=json
# Local development default. Installed Linux services should use
# /var/log/evepilot/evepilot.log from /etc/evepilot/evepilot.env.
EVEPILOT_LOG_FILE_PATH=logs/evepilot.log

# Optional advanced logging mode.
# If set, this overrides the simple EVEPILOT_LOG_* settings above.
# EVEPILOT_LOG_TARGETS_JSON='[{"name":"stdout-json","output":"stdout","level":"INFO","format":"json"},{"name":"file-text","output":"file","level":"INFO","format":"text","file_path":"logs/evepilot.log"}]'
